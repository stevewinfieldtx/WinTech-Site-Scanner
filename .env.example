# Database (Railway injects this automatically in production)
# For local dev, paste your Railway PostgreSQL URL here
DATABASE_URL=

# Admin credentials
ADMIN_EMAIL=you@yourcompany.com
ADMIN_PASSWORD=changeme

# Secret used to sign admin session tokens (HMAC). Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Shared password for WinTech team members to unlock any report
TEAM_PASSWORD=

# Private key that lets ONLY you force a fresh (uncached) re-scan.
# Visit the site as https://your-app/?fk=THIS_VALUE to bypass the 24h cache.
# Public visitors without this key can never trigger a forced re-scan.
FORCE_RESCAN_KEY=

# Scan result caching. Currently OFF (omit or leave false = every scan runs fresh).
# Set to true to re-enable the 24h cache once the scanner output is stable.
SCAN_CACHE_ENABLED=false

# Emails allowed to deep-scan ANY domain and exempt from the monthly cap (comma-separated).
ALLOWED_EMAILS=you@wintechpartners.com

# Free users are capped at this many deep scans per calendar month.
FREE_SCANS_PER_MONTH=10

# Audience Intel — OpenRouter key + the three models (set each independently).
# Model 1 also powers the free single-model "short" read.
OPENROUTER_API_KEY=
AUDIENCE_MODEL_1=openai/gpt-4o-mini
AUDIENCE_MODEL_2=google/gemini-2.0-flash-001
AUDIENCE_MODEL_3=anthropic/claude-3.5-haiku

# Server
PORT=3000
NODE_ENV=production
